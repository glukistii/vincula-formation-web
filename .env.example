# =========================================
# Supabase
# =========================================
# Project URL (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://vapffndxsudqegyrlvij.supabase.co

# Anonymous (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role key — SERVER-SIDE ONLY (used by webhook handler)
# NEVER expose this in client code
SUPABASE_SERVICE_ROLE_KEY=

# =========================================
# WordPress / WooCommerce
# =========================================
# URL of the WordPress site
NEXT_PUBLIC_WP_URL=https://www.vincula-formation.com

# Secret used to sign WooCommerce webhook payloads
# Set the same value in WP -> WooCommerce -> Settings -> Advanced -> Webhooks -> Secret
WOOCOMMERCE_WEBHOOK_SECRET=

# When set to "false", the webhook will NOT auto-create Supabase accounts
# for customers who don't yet have one. Default is "true".
WEBHOOK_AUTO_CREATE_USERS=true

# =========================================
# Site
# =========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
